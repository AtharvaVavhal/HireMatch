# ──────────────────────────────────────────────
# HireMatch — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
#   cp .env.example .env

# ── Flask ──────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-this

# 'development' or 'production'
FLASK_ENV=development

# Port (default 5000)
PORT=5000

# ── File Handling ──────────────────────────────
# Absolute paths to upload/output directories.
# Leave blank to use defaults (project_root/uploads, project_root/outputs).
UPLOAD_FOLDER=
OUTPUT_FOLDER=

# Maximum upload size in MB (default: 16)
MAX_UPLOAD_MB=16

# Maximum resumes in a single batch (default: 20)
MAX_BATCH_RESUMES=20

# ── Logging ────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Set to 1 to write logs/hirematch.log and logs/errors.log
LOG_TO_FILE=0
